{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TinyMD",
  "version": "1.0.0-beat.2",
  "identifier": "com.codex.rust-milkdown",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TinyMD",
        "width": 1600,
        "height": 960,
        "minWidth": 1240,
        "minHeight": 760,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "TinyMD Markdown Document",
        "description": "TinyMD Markdown Document"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
